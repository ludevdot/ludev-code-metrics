{
  "name": "ludev-code-metrics",
  "displayName": "Ludev Code Metrics",
  "description": "Shows Claude Code subscription usage (session and weekly) in the Status Bar",
  "version": "1.1.12",
  "publisher": "ludevdot",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ludevdot/ludev-code-metrics"
  },
  "bugs": {
    "url": "https://github.com/ludevdot/ludev-code-metrics/issues"
  },
  "homepage": "",
  "keywords": [
    "claude",
    "anthropic",
    "claude code",
    "usage",
    "status bar",
    "ludev",
    "ludevdot",
    "metrics",
    "insights",
    "ai"
  ],
  "icon": "media/ludev-logo.png",
  "galleryBanner": {
    "color": "#1E1E1E",
    "theme": "dark"
  },
  "screenshots": [
    {
      "path": "assets/code-metrics-1.png",
      "description": "Session and weekly usage overview"
    },
    {
      "path": "assets/code-metrics-2.png",
      "description": "Skills management and installation"
    },
    {
      "path": "assets/code-metrics-3.png",
      "description": "Inital state Code Metrics"
    }
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "l10n": "./l10n",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "ludevMetricsSidebar",
          "title": "%view.container.title%",
          "icon": "media/activity.svg"
        }
      ]
    },
    "views": {
      "ludevMetricsSidebar": [
        {
          "type": "webview",
          "id": "ludevMetrics.sidebar",
          "name": "%view.usage.name%"
        }
      ]
    },
    "commands": [
      {
        "command": "ludevMetrics.refresh",
        "title": "%command.refresh.title%"
      },
      {
        "command": "ludevMetrics.setToken",
        "title": "%command.setToken.title%"
      },
      {
        "command": "ludevMetrics.setCredentialsPath",
        "title": "%command.setCredentialsPath.title%"
      },
      {
        "command": "ludevMetrics.installSkill",
        "title": "%command.installSkill.title%"
      }
    ],
    "configuration": {
      "title": "%config.title%",
      "properties": {
        "ludevMetrics.autoRefresh": {
          "type": "boolean",
          "default": false,
          "description": "%config.autoRefresh.description%"
        },
        "ludevMetrics.autoRefreshInterval": {
          "type": "number",
          "default": 5,
          "minimum": 1,
          "maximum": 60,
          "description": "%config.autoRefreshInterval.description%"
        },
        "ludevMetrics.manualToken": {
          "type": "string",
          "default": "",
          "description": "%config.manualToken.description%"
        },
        "ludevMetrics.barStyle": {
          "type": "string",
          "enum": [
            "gradient",
            "blocks",
            "icon-only",
            "icon+gradient"
          ],
          "enumDescriptions": [
            "%config.barStyle.gradient%",
            "%config.barStyle.blocks%",
            "%config.barStyle.iconOnly%",
            "%config.barStyle.iconGradient%"
          ],
          "default": "gradient",
          "description": "%config.barStyle.description%"
        },
        "ludevMetrics.credentialsPath": {
          "type": "string",
          "default": "",
          "description": "%config.credentialsPath.description%"
        },
        "ludevMetrics.warningThreshold": {
          "type": "number",
          "default": 80,
          "minimum": 0,
          "maximum": 100,
          "description": "%config.warningThreshold.description%"
        },
        "ludevMetrics.viewMode": {
          "type": "string",
          "enum": [
            "extended",
            "compact"
          ],
          "default": "extended",
          "description": "%config.viewMode.description%"
        },
        "ludevMetrics.accounts": {
          "type": "array",
          "default": [],
          "description": "%config.accounts.description%",
          "items": {
            "type": "object",
            "required": [
              "email",
              "token"
            ],
            "properties": {
              "email": {
                "type": "string",
                "description": "Account email, set automatically when capturing a session."
              },
              "subscriptionType": {
                "type": "string",
                "description": "Subscription type, set automatically when capturing a session."
              },
              "token": {
                "type": "string",
                "description": "OAuth token. Set automatically. Do not commit to version control."
              }
            }
          }
        }
      }
    }
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm run precommit-version"
  },
  "scripts": {
    "compile": "esbuild src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node",
    "watch": "esbuild src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "vscode:prepublish": "pnpm run typecheck && esbuild src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node --minify",
    "changeset": "changeset",
    "version": "changeset version",
    "precommit-version": "node scripts/precommit-version.mjs",
    "postinstall": "simple-git-hooks"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.27.3",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^5.3.0",
    "vitest": "^2.1.9"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "simple-git-hooks",
      "esbuild"
    ]
  }
}
