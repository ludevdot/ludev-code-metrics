{
  "name": "claude-usage-indicator",
  "displayName": "Claude Code Usage",
  "description": "Shows Claude Code subscription usage (session and weekly) in the Status Bar",
  "version": "0.0.5",
  "publisher": "claude-usage",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/YOUR_GITHUB_USERNAME/claude-usage-indicator.git"
  },
  "bugs": {
    "url": "https://github.com/YOUR_GITHUB_USERNAME/claude-usage-indicator/issues"
  },
  "homepage": "https://github.com/YOUR_GITHUB_USERNAME/claude-usage-indicator#readme",
  "keywords": [
    "claude",
    "anthropic",
    "claude code",
    "usage",
    "status bar",
    "ai"
  ],
  "icon": "media/test2.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "l10n": "./l10n",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "claudeUsageSidebar",
          "title": "%view.container.title%",
          "icon": "media/test.svg"
        }
      ]
    },
    "views": {
      "claudeUsageSidebar": [
        {
          "type": "webview",
          "id": "claudeUsage.sidebar",
          "name": "%view.usage.name%"
        }
      ]
    },
    "commands": [
      {
        "command": "claudeUsage.refresh",
        "title": "%command.refresh.title%"
      },
      {
        "command": "claudeUsage.setToken",
        "title": "%command.setToken.title%"
      },
      {
        "command": "claudeUsage.setCredentialsPath",
        "title": "%command.setCredentialsPath.title%"
      },
      {
        "command": "claudeUsage.installSkill",
        "title": "%command.installSkill.title%"
      }
    ],
    "configuration": {
      "title": "%config.title%",
      "properties": {
        "claudeUsage.refreshInterval": {
          "type": "number",
          "default": 60,
          "minimum": 30,
          "description": "%config.refreshInterval.description%"
        },
        "claudeUsage.manualToken": {
          "type": "string",
          "default": "",
          "description": "%config.manualToken.description%"
        },
        "claudeUsage.barStyle": {
          "type": "string",
          "enum": [
            "gradient",
            "blocks",
            "icon-only",
            "icon+gradient"
          ],
          "enumDescriptions": [
            "%config.barStyle.gradient%",
            "%config.barStyle.blocks%",
            "%config.barStyle.iconOnly%",
            "%config.barStyle.iconGradient%"
          ],
          "default": "gradient",
          "description": "%config.barStyle.description%"
        },
        "claudeUsage.credentialsPath": {
          "type": "string",
          "default": "",
          "description": "%config.credentialsPath.description%"
        },
        "claudeUsage.warningThreshold": {
          "type": "number",
          "default": 80,
          "minimum": 0,
          "maximum": 100,
          "description": "%config.warningThreshold.description%"
        },
        "claudeUsage.viewMode": {
          "type": "string",
          "enum": [
            "extended",
            "compact"
          ],
          "default": "extended",
          "description": "%config.viewMode.description%"
        }
      }
    }
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm run precommit-version"
  },
  "scripts": {
    "compile": "esbuild src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node",
    "watch": "esbuild src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "vscode:prepublish": "pnpm run typecheck && esbuild src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node --minify",
    "changeset": "changeset",
    "version": "changeset version",
    "precommit-version": "node scripts/precommit-version.mjs",
    "postinstall": "simple-git-hooks"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.27.3",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^5.3.0",
    "vitest": "^2.1.9"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "simple-git-hooks",
      "esbuild"
    ]
  }
}
